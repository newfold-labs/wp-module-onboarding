{
	"name": "@newfold-labs/wp-module-onboarding",
	"version": "3.0.2",
	"description": "Next-generation WordPress Onboarding for WordPress sites at Newfold Digital.",
	"license": "GPL-2.0-or-later",
	"private": true,
	"author": {
		"name": "Dave Ryan",
		"email": "dave@bluehost.com"
	},
	"devDependencies": {
		"@tailwindcss/forms": "^0.5.10",
		"@testing-library/cypress": "^10.0.3",
		"@wordpress/base-styles": "^5.22.0",
		"@wordpress/env": "^10.22.0",
		"@wordpress/icons": "^10.22.0",
		"@wordpress/scripts": "^30.15.0",
		"axe-core": "^4.10.3",
		"cypress": "^14.3.2",
		"cypress-axe": "^1.6.0",
		"eslint-import-resolver-alias": "^1.1.2",
		"node-fetch": "^3.3.2",
		"tailwindcss": "^3.4.17",
		"webpack-merge": "^6.0.1"
	},
	"scripts": {
		"build": "wp-scripts build ./src/onboarding.js ./src/Scripts/sitegen-theme-marker/sitegen-theme-marker.js ./src/Scripts/sitegen-theme-marker/sitegen-theme-marker.css  ./src/Scripts/onboarding-restart-button/onboarding-restart-button.js ./src/Scripts/onboarding-restart-button/onboarding-restart-button.css ./src/DesignStudio/onboarding-design-studio.js ./src/DesignStudio/onboarding-design-studio.css",
		"format": "wp-scripts format ./src",
		"start": "wp-scripts start ./src/onboarding.js ./src/Scripts/sitegen-theme-marker/sitegen-theme-marker.js ./src/Scripts/sitegen-theme-marker/sitegen-theme-marker.css  ./src/Scripts/onboarding-restart-button/onboarding-restart-button.js ./src/Scripts/onboarding-restart-button/onboarding-restart-button.css ./src/DesignStudio/onboarding-design-studio.js ./src/DesignStudio/onboarding-design-studio.css",
		"set-version-bump": "npm run set-version-patch",
		"post-set-version": "rm -rf ./build",
		"lint:js": "wp-scripts lint-js ./src",
		"lint:js:fix": "wp-scripts lint-js ./src --fix",
		"test:e2e": "npx cypress run",
		"test:unit": "npx wp-env run phpunit 'phpunit -c /var/www/html/wp-content/plugins//phpunit.xml --verbose'"
	},
	"dependencies": {
		"@heroicons/react": "^2.2.0",
		"@newfold/js-utility-ui-analytics": "^1.4.0",
		"@newfold/ui-component-library": "^1.3.0",
		"@sentry/react": "^9.36.0",
		"@wordpress/api-fetch": "^7.17.0",
		"@wordpress/data": "^10.17.0",
		"@wordpress/element": "^6.17.0",
		"@wordpress/interface": "^9.7.0",
		"@wordpress/media-utils": "^5.24.0",
		"@wordpress/style-engine": "^2.22.0",
		"bytes": "^3.1.2",
		"classnames": "^2.3.2",
		"colord": "^2.9.3",
		"motion": "^11.18.1",
		"react-router-dom": "^7.5.1"
	}
}